{
  "version": "0.2",
  "language": "en",
  "ignorePaths": ["node_modules/**", ".next/**", "package-lock.json", "*.log"],
  "ignoreRegExpList": [
    "data:[^)\"']+",
    "#[0-9a-fA-F]{3,8}\\b"
