    "autocapitalize",
    "autocorrect",
    "autoprefixer",
    "avionics",
    "backdrop",
    "colophon",
    "combobox",
    "descendant",
    "feturbulence",
    "filesystem",
    "fractalnoise",
    "framer",
    "fraunces",
    "ghostty",
    "grotesk",
    "hairline",
    "hairlines",
    "hanken",
    "keyshortcuts",
    "khiem",
    "kylev",
    "labelledby",
    "listbox",
    "marquee",
    "martian",
    "noopener",
    "noreferrer",
    "numoctaves",
    "oklch",
    "postcss",
    "roving",
    "scanline",
    "scanlines",
    "skippable",
    "stitchtiles",
    "subsystem",
    "swinburne",
    "tailwindcss",
    "telemetry",
    "uplink",
    "vercel",
    "vignette",
    "xmlns"
  ]
